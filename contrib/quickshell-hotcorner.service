[Unit]
Description=Quickshell Overview Hotcorner
After=quickshell-overview.service

[Service]
Type=simple
ExecStart=/usr/bin/bash /home/lowell/.config/hypr/scripts/hotcorner.sh
Environment=PATH=/usr/local/bin:/usr/bin:/bin
Environment=WAYLAND_DISPLAY=wayland-1
Restart=on-failure
RestartSec=2

[Install]
WantedBy=graphical-session.target
